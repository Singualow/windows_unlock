{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "蓝牙解锁",
  "version": "0.2.5",
  "identifier": "com.singu.proximityunlock.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "蓝牙解锁",
        "width": 1440,
        "height": 900,
        "minWidth": 980,
        "minHeight": 680,
        "center": true,
        "visible": false,
        "decorations": false,
        "resizable": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: data:; style-src 'self' 'unsafe-inline'; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
